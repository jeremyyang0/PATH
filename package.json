{
  "name": "ele-tree-viewer",
  "displayName": "Ele Tree Viewer",
  "description": "显示Python代码中Ele类变量的树形结构",
  "version": "0.0.8",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:python",
    "onCommand:eleTreeViewer.refresh",
    "onCommand:methodsViewer.refresh"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "eleTreeViewerContainer",
          "title": "Ele变量树",
          "icon": "$(list-tree)"
        }
      ]
    },
    "views": {
      "eleTreeViewerContainer": [
        {
          "id": "eleTreeViewer",
          "name": "Ele变量树",
          "when": "true",
          "dragAndDropController": "eleTreeViewer.dragAndDropController"
        },
        {
          "id": "methodsViewer",
          "name": "方法树",
          "when": "true",
          "dragAndDropController": "methodsViewer.dragAndDropController"
        }
      ]
    },
    "commands": [
      {
        "command": "eleTreeViewer.refresh",
        "title": "刷新",
        "icon": "$(refresh)"
      },
      {
        "command": "methodsViewer.refresh",
        "title": "刷新",
        "icon": "$(refresh)"
      },
      {
        "command": "eleTreeViewer.expandAll",
        "title": "展开所有",
        "icon": "$(expand-all)"
      },
      {
        "command": "eleTreeViewer.collapseAll",
        "title": "收起所有",
        "icon": "$(collapse-all)"
      },
      {
        "command": "methodsViewer.expandAll",
        "title": "展开所有",
        "icon": "$(expand-all)"
      },
      {
        "command": "methodsViewer.collapseAll",
        "title": "收起所有",
        "icon": "$(collapse-all)"
      },
      {
        "command": "eleTreeViewer.dragToEditor",
        "title": "拖拽到编辑器"
      },
      {
        "command": "methodsViewer.dragToEditor",
        "title": "拖拽到编辑器"
      },
      {
        "command": "eleTreeViewer.search",
        "title": "搜索",
        "icon": "$(search)"
      },
      {
        "command": "methodsViewer.search",
        "title": "搜索",
        "icon": "$(search)"
      },
      {
        "command": "eleTreeViewer.clearSearch",
        "title": "清除搜索",
        "icon": "$(clear-all)"
      },
      {
        "command": "methodsViewer.clearSearch",
        "title": "清除搜索",
        "icon": "$(clear-all)"
      },
      {
        "command": "eleTreeViewer.addOperation",
        "title": "添加操作"
      },
      {
        "command": "eleTreeViewer.addClickOperation",
        "title": "点击"
      },
      {
        "command": "eleTreeViewer.addDoubleClickOperation",
        "title": "双击"
      },
      {
        "command": "eleTreeViewer.openFile",
        "title": "打开文件并跳转到行"
      },
      {
        "command": "methodsViewer.openFile",
        "title": "打开文件并跳转到行"
      },
      {
        "command": "methodsViewer.jumpToMethod",
        "title": "跳转到方法"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "eleTreeViewer.refresh",
          "when": "view == eleTreeViewer",
          "group": "navigation"
        },
        {
          "command": "methodsViewer.refresh",
          "when": "view == methodsViewer",
          "group": "navigation"
        },
        {
          "command": "eleTreeViewer.expandAll",
          "when": "view == eleTreeViewer",
          "group": "navigation"
        },
        {
          "command": "eleTreeViewer.collapseAll",
          "when": "view == eleTreeViewer",
          "group": "navigation"
        },
        {
          "command": "methodsViewer.expandAll",
          "when": "view == methodsViewer",
          "group": "navigation"
        },
        {
          "command": "eleTreeViewer.search",
          "when": "view == eleTreeViewer",
          "group": "navigation"
        },
        {
          "command": "methodsViewer.search",
          "when": "view == methodsViewer",
          "group": "navigation"
        },
        {
          "command": "eleTreeViewer.clearSearch",
          "when": "view == eleTreeViewer",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "methodsViewer.dragToEditor",
          "when": "view == methodsViewer && viewItem == methodTreeLeaf",
          "group": "inline"
        },
        {
          "command": "eleTreeViewer.dragToEditor",
          "when": "view == eleTreeViewer && viewItem == eleTreeLeaf",
          "group": "inline"
        },
        {
          "command": "eleTreeViewer.addClickOperation",
          "when": "view == eleTreeViewer && viewItem == eleTreeLeaf",
          "group": "navigation"
        },
        {
          "command": "eleTreeViewer.addDoubleClickOperation",
          "when": "view == eleTreeViewer && viewItem == eleTreeLeaf",
          "group": "navigation"
        },
        {
          "command": "methodsViewer.jumpToMethod",
          "when": "view == methodsViewer && viewItem == methodTreeLeaf",
          "group": "navigation@10"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.60.0",
    "@types/node": "14.x",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "eslint": "^8.44.0",
    "typescript": "^5.1.6",
    "@vscode/test-electron": "^2.3.4"
  },
  "dependencies": {}
}