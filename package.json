{
  "name": "path-plugin-auto-test-homie",
  "displayName": "PATH (Plugin Auto Test Homie)",
  "description": "Python 自动化测试辅助插件，提供元素树、方法树、PATH 文件树和 AI 代码生成功能",
  "version": "2.1.0",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Testing",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:python",
    "onCommand:eleTreeViewer.refresh",
    "onCommand:methodsViewer.refresh",
    "onCommand:pathFileTree.refresh",
    "onCommand:pathSniffViewer.refresh"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "eleTreeViewerContainer",
          "title": "PATH",
          "icon": "resources/icons/ele-tree.svg"
        },
        {
          "id": "eleSecondaryViewContainer",
          "title": "PATH",
          "icon": "resources/icons/secondary-view.svg"
        },
        {
          "id": "pathSniffViewerContainer",
          "title": "PATH Sniff",
          "icon": "resources/icons/sniff-tree.svg"
        }
      ],
      "panel": [
        {
          "id": "pathSniffPanelContainer",
          "title": "PATH Sniff",
          "icon": "resources/icons/sniff-tree.svg"
        }
      ]
    },
    "views": {
      "eleTreeViewerContainer": [
        {
          "id": "eleTreeViewer",
          "name": "测试元素树",
          "type": "webview",
          "when": "true",
          "icon": "resources/icons/ele-tree.svg"
        },
        {
          "id": "methodsViewer",
          "name": "测试方法树",
          "type": "webview",
          "when": "true",
          "icon": "resources/icons/methods-tree.svg"
        },
        {
          "id": "pathFileTree",
          "name": "PATH 文件树",
          "when": "true",
          "icon": "resources/icons/file-tree.svg"
        }
      ],
      "pathSniffViewerContainer": [
        {
          "id": "pathSniffViewer",
          "name": "Sniff",
          "type": "webview",
          "when": "true",
          "icon": "resources/icons/sniff-tree.svg"
        }
      ],
      "pathSniffPanelContainer": [
        {
          "id": "pathSniffOverviewViewer",
          "name": "Sniff Overview",
          "type": "webview",
          "when": "true",
          "icon": "resources/icons/sniff-overview.svg"
        },
        {
          "id": "pathSniffLogsViewer",
          "name": "Sniff Logs",
          "type": "webview",
          "when": "true",
          "icon": "resources/icons/sniff-logs.svg"
        }
      ],
      "eleSecondaryViewContainer": [
        {
          "id": "eleSecondaryView",
          "name": "测试辅助视图",
          "type": "webview",
          "when": "true",
          "icon": "resources/icons/secondary-view.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "eleTreeViewer.refresh",
        "title": "刷新",
        "icon": "$(refresh)"
      },
      {
        "command": "methodsViewer.refresh",
        "title": "刷新",
        "icon": "$(refresh)"
      },
      {
        "command": "pathFileTree.refresh",
        "title": "刷新",
        "icon": "$(refresh)"
      },
      {
        "command": "pathSniffViewer.refresh",
        "title": "刷新",
        "icon": "$(refresh)"
      },
      {
        "command": "pathFileTree.openItem",
        "title": "打开"
      },
      {
        "command": "pathFileTree.newFile",
        "title": "新建文件...",
        "icon": "$(new-file)"
      },
      {
        "command": "pathFileTree.newFolder",
        "title": "新建文件夹...",
        "icon": "$(new-folder)"
      },
      {
        "command": "pathFileTree.rename",
        "title": "重命名"
      },
      {
        "command": "pathFileTree.delete",
        "title": "删除"
      },
      {
        "command": "pathFileTree.revealInOS",
        "title": "在系统资源管理器中显示"
      },
      {
        "command": "pathFileTree.copyPath",
        "title": "复制路径"
      },
      {
        "command": "pathFileTree.copyRelativePath",
        "title": "复制相对路径"
      },
      {
        "command": "pathFileTree.findInFolder",
        "title": "在文件夹中搜索"
      },
      {
        "command": "pathFileTree.createCase",
        "title": "Create Case (创建用例)"
      },
      {
        "command": "eleTreeViewer.dragToEditor",
        "title": "拖拽到编辑器"
      },
      {
        "command": "methodsViewer.dragToEditor",
        "title": "拖拽到编辑器"
      },
      {
        "command": "eleTreeViewer.search",
        "title": "搜索",
        "icon": "$(search)"
      },
      {
        "command": "methodsViewer.search",
        "title": "搜索",
        "icon": "$(search)"
      },
      {
        "command": "eleTreeViewer.clearSearch",
        "title": "清除搜索",
        "icon": "$(clear-all)"
      },
      {
        "command": "methodsViewer.clearSearch",
        "title": "清除搜索",
        "icon": "$(clear-all)"
      },
      {
        "command": "eleTreeViewer.addOperation",
        "title": "添加操作"
      },
      {
        "command": "eleTreeViewer.addClickOperation",
        "title": "点击"
      },
      {
        "command": "eleTreeViewer.addDoubleClickOperation",
        "title": "双击"
      },
      {
        "command": "eleTreeViewer.openFile",
        "title": "打开文件并跳转到行"
      },
      {
        "command": "methodsViewer.openFile",
        "title": "打开文件并跳转到行"
      },
      {
        "command": "methodsViewer.jumpToMethod",
        "title": "跳转到方法"
      },
      {
        "command": "eleTreeViewer.openSecondaryView",
        "title": "打开辅助视图",
        "icon": "$(window)"
      },
      {
        "command": "eleSecondaryView.focus",
        "title": "显示辅助视图"
      },
      {
        "command": "eleTreeViewer.createCase",
        "title": "Create Case (创建用例)"
      },
      {
        "command": "eleTreeViewer.debugMarkrunner",
        "title": "Debug Markrunner"
      },
      {
        "command": "eleTreeViewer.aiGeneration",
        "title": "AI Generation"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "eleTreeViewer.refresh",
          "when": "view == eleTreeViewer",
          "group": "navigation"
        },
        {
          "command": "methodsViewer.refresh",
          "when": "view == methodsViewer",
          "group": "navigation"
        },
        {
          "command": "pathFileTree.refresh",
          "when": "view == pathFileTree",
          "group": "navigation@1"
        },
        {
          "command": "pathSniffViewer.refresh",
          "when": "view == pathSniffViewer",
          "group": "navigation"
        },
        {
          "command": "pathFileTree.newFile",
          "when": "view == pathFileTree",
          "group": "navigation@2"
        },
        {
          "command": "pathFileTree.newFolder",
          "when": "view == pathFileTree",
          "group": "navigation@3"
        },
        {
          "command": "pathFileTree.revealInOS",
          "when": "view == pathFileTree",
          "group": "2_root"
        },
        {
          "command": "pathFileTree.copyPath",
          "when": "view == pathFileTree",
          "group": "2_root"
        },
        {
          "command": "pathFileTree.copyRelativePath",
          "when": "view == pathFileTree",
          "group": "2_root"
        },
        {
          "command": "pathFileTree.findInFolder",
          "when": "view == pathFileTree",
          "group": "2_root"
        },
        {
          "command": "pathFileTree.createCase",
          "when": "view == pathFileTree",
          "group": "2_root"
        }
      ],
      "view/item/context": [
        {
          "command": "pathFileTree.openItem",
          "when": "view == pathFileTree && viewItem == pathFileTreeFile",
          "group": "inline"
        },
        {
          "command": "pathFileTree.newFile",
          "when": "view == pathFileTree",
          "group": "0_new@1"
        },
        {
          "command": "pathFileTree.newFolder",
          "when": "view == pathFileTree",
          "group": "0_new@2"
        },
        {
          "command": "pathFileTree.rename",
          "when": "view == pathFileTree",
          "group": "1_modification@1"
        },
        {
          "command": "pathFileTree.delete",
          "when": "view == pathFileTree",
          "group": "1_modification@2"
        },
        {
          "command": "pathFileTree.revealInOS",
          "when": "view == pathFileTree",
          "group": "2_cutcopypaste@1"
        },
        {
          "command": "pathFileTree.copyPath",
          "when": "view == pathFileTree",
          "group": "2_cutcopypaste@2"
        },
        {
          "command": "pathFileTree.copyRelativePath",
          "when": "view == pathFileTree",
          "group": "2_cutcopypaste@3"
        },
        {
          "command": "pathFileTree.findInFolder",
          "when": "view == pathFileTree && viewItem == pathFileTreeFolder",
          "group": "3_search"
        },
        {
          "command": "pathFileTree.createCase",
          "when": "view == pathFileTree",
          "group": "4_workspace"
        }
      ],
      "explorer/context": [
        {
          "command": "eleTreeViewer.createCase",
          "group": "2_workspace"
        }
      ],
      "editor/context": [
        {
          "command": "eleTreeViewer.debugMarkrunner",
          "group": "navigation",
          "when": "resourceLangId == python && resourceFilename =~ /^test_.+\\.py$/"
        },
        {
          "command": "eleTreeViewer.aiGeneration",
          "group": "navigation",
          "when": "resourceLangId == python && resourceFilename =~ /^test_.+\\.py$/"
        }
      ]
    },
    "keybindings": [
      {
        "command": "pathFileTree.newFile",
        "key": "a",
        "when": "listFocus && focusedView == 'pathFileTree' && !inputFocus"
      },
      {
        "command": "pathFileTree.newFolder",
        "key": "shift+a",
        "when": "listFocus && focusedView == 'pathFileTree' && !inputFocus"
      },
      {
        "command": "pathFileTree.rename",
        "key": "f2",
        "when": "listFocus && focusedView == 'pathFileTree' && !inputFocus"
      },
      {
        "command": "pathFileTree.delete",
        "key": "delete",
        "when": "listFocus && focusedView == 'pathFileTree' && !inputFocus"
      }
    ],
    "configurationDefaults": {
      "files.associations": {
        ".order": "json"
      }
    },
    "configuration": {
      "title": "PATH Plugin Settings",
      "properties": {
        "path.zentao.host": {
          "type": "string",
          "default": "",
          "description": "禅道服务器地址 (例如: 10.0.18.30)"
        },
        "path.zentao.username": {
          "type": "string",
          "default": "",
          "description": "禅道用户名"
        },
        "path.zentao.password": {
          "type": "string",
          "default": "",
          "description": "禅道密码",
          "format": "password"
        },
        "path.appName": {
          "type": "string",
          "default": "",
          "description": "应用名称 (如果有值，创建用例时将不会弹出输入框)"
        },
        "path.markrunner.contextLaunchConfigName": {
          "type": "string",
          "default": "MarkRunner Context Debug",
          "description": "右键调试用例时使用的 Launch Config 名称"
        },
        "path.ai.url": {
          "type": "string",
          "default": "",
          "description": "AI 模型服务 URL (例如: http://127.0.0.1:8045/v1)"
        },
        "path.ai.apiKey": {
          "type": "string",
          "default": "",
          "description": "AI API 密钥"
        },
        "path.ai.model": {
          "type": "string",
          "default": "",
          "description": "AI 模型名称 (例如: gemini-3-flash)"
        },
        "path.ai.logConversation": {
          "type": "boolean",
          "default": false,
          "description": "记录 AI 对话过程"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts"
  },
  "files": [
    "out/**/*",
    "resources/**/*",
    "README.md",
    "CHANGELOG.md"
  ],
  "devDependencies": {
    "@types/vscode": "^1.60.0",
    "@types/node": "14.x",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vscode/test-electron": "^2.3.4",
    "eslint": "^8.44.0",
    "typescript": "^5.1.6"
  },
  "dependencies": {}
}
